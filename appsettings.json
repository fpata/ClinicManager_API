{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=clinic;User=clinic;Password=Clinic@110;"
  },
  "Jwt": {
    "Key": "KeyForClinicManagerJWTTokenForEncryptionPassKeyKeyForClin",
    "Issuer": "ClinicManagerIssuer"
  },
  "EmailSettings": {
    "SmtpServer": "",
    "Port": "587",
    "SenderEmail": "noreply@reliefdentalclinic.com",
    "SenderName": "Relief Dental Clinic",
    "Username": "",
    "Password": "",
    "EnableSsl": "true"
  },
  "SmsSettings": {
    "AccountSid": "",
    "AuthToken": "",
    "FromPhoneNumber": ""
  }
}
